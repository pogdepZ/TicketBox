generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum ArtistBioStatus {
  EMPTY
  PROCESSING
  DONE
  FAILED
}

enum TicketTypeStatus {
  ACTIVE
  PAUSED
  SOLD_OUT
  HIDDEN
}

enum ReservationStatus {
  HELD
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  PAID
  PAYMENT_FAILED
  EXPIRED
  CANCELLED
  REFUND_REQUIRED
}

enum PaymentMethod {
  VNPAY
  MOMO
}

enum PaymentGateway {
  VNPAY
  MOMO
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  REFUNDED
}

enum CheckinDeviceStatus {
  ACTIVE
  BLOCKED
  LOST
}

enum CheckinMode {
  ONLINE
  OFFLINE_SYNC
}

enum CheckinResult {
  ACCEPTED
  REJECTED
  DUPLICATE
}

enum GuestImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum GuestRowStatus {
  PENDING
  VALID
  INVALID
}

enum GuestStatus {
  ACTIVE
  CHECKED_IN
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  ZALO
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum WaitingRoomStatus {
  WAITING
  ADMITTED
  EXPIRED
  BLOCKED
}

enum AssetStatus {
  UPLOADED
  PROCESSING
  DONE
  FAILED
}

/**
 * =========================
 * AUTH / RBAC
 * =========================
 */

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique @db.VarChar(255)
  phone        String?    @db.VarChar(20)
  password String?    @map("password") @db.VarChar(255)
  fullName     String     @map("full_name") @db.VarChar(100)
  status       UserStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  roles              UserRole[]
  createdConcerts    Concert[]            @relation("ConcertCreatedBy")
  reservations       Reservation[]
  ticketQuotas       UserTicketQuota[]
  orders             Order[]
  ownedTickets       Ticket[]             @relation("TicketOwner")
  scannedTickets     Ticket[]             @relation("TicketScannedBy")
  checkinDevices     CheckinDevice[]
  checkinEvents      CheckinEvent[]
  scannedGuests      GuestList[]          @relation("GuestScannedBy")
  uploadedAssets     ArtistAsset[]        @relation("ArtistAssetUploadedBy")
  notifications      Notification[]
  idempotencyRecords IdempotencyRecord[]
  auditLogs          AuditLog[]           @relation("AuditActor")
  waitingRooms       WaitingRoomSession[]

  @@index([email])
  @@map("users")
}

model Role {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(50)

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String @unique @db.VarChar(100)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

/**
 * =========================
 * CONCERT / SEAT MAP / TICKET TYPES
 * =========================
 */

model Concert {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name        String  @db.VarChar(200)
  description String?

  artistName      String?         @map("artist_name") @db.VarChar(200)
  artistBio       String?         @map("artist_bio")
  artistBioStatus ArtistBioStatus @default(EMPTY) @map("artist_bio_status")

  venueName    String   @map("venue_name") @db.VarChar(200)
  venueAddress String   @map("venue_address")
  eventDate    DateTime @map("event_date") @db.Timestamptz(6)

  posterUrl     String? @map("poster_url") @db.VarChar(500)
  seatMapSvgUrl String? @map("seat_map_svg_url") @db.VarChar(500)

  status      ConcertStatus @default(DRAFT)
  createdById String?       @map("created_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User? @relation("ConcertCreatedBy", fields: [createdById], references: [id])

  seatZones           SeatZone[]
  ticketTypes         TicketType[]
  reservations        Reservation[]
  orders              Order[]
  guestImportBatches  GuestImportBatch[]
  guestList           GuestList[]
  artistAssets        ArtistAsset[]
  checkinDevices      CheckinDevice[]
  waitingRoomSessions WaitingRoomSession[]

  @@index([status, eventDate])
  @@map("concerts")
}

model SeatZone {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  code         String  @db.VarChar(50)
  name         String  @db.VarChar(100)
  color        String? @db.VarChar(7)
  svgElementId String? @map("svg_element_id") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  concert     Concert      @relation(fields: [concertId], references: [id], onDelete: Cascade)
  ticketTypes TicketType[]

  @@unique([concertId, code])
  @@unique([id, concertId])
  @@map("seat_zones")
}

model TicketType {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  /**
   * seatZoneId + concertId relation dùng để đảm bảo
   * seat zone thuộc đúng concert.
   */
  seatZoneId String? @map("seat_zone_id") @db.Uuid

  name  String  @db.VarChar(50)
  price Decimal @db.Decimal(12, 2)

  totalQuantity Int @map("total_quantity")
  remaining     Int
  maxPerUser    Int @default(4) @map("max_per_user")

  saleStartAt DateTime? @map("sale_start_at") @db.Timestamptz(6)
  saleEndAt   DateTime? @map("sale_end_at") @db.Timestamptz(6)

  status TicketTypeStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  concert  Concert   @relation(fields: [concertId], references: [id], onDelete: Cascade)
  seatZone SeatZone? @relation(fields: [seatZoneId, concertId], references: [id, concertId])

  reservationItems ReservationItem[]
  orderItems       OrderItem[]
  tickets          Ticket[]
  quotas           UserTicketQuota[]

  @@unique([concertId, name])
  @@index([concertId])
  @@index([saleStartAt, saleEndAt])
  @@map("ticket_types")
}

/**
 * =========================
 * RESERVATION / QUOTA
 * =========================
 */

model Reservation {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  concertId String @map("concert_id") @db.Uuid

  status    ReservationStatus @default(HELD)
  expiresAt DateTime          @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id])
  concert Concert @relation(fields: [concertId], references: [id])

  items ReservationItem[]
  order Order?

  @@index([userId])
  @@index([status, expiresAt])
  @@map("reservations")
}

model ReservationItem {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String @map("reservation_id") @db.Uuid
  ticketTypeId  String @map("ticket_type_id") @db.Uuid

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  ticketType  TicketType  @relation(fields: [ticketTypeId], references: [id])

  @@unique([reservationId, ticketTypeId])
  @@index([ticketTypeId])
  @@map("reservation_items")
}

model UserTicketQuota {
  userId       String @map("user_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid

  heldQuantity Int @default(0) @map("held_quantity")
  paidQuantity Int @default(0) @map("paid_quantity")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@id([userId, ticketTypeId])
  @@map("user_ticket_quotas")
}

/**
 * =========================
 * ORDER / PAYMENT
 * =========================
 */

model Order {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String @map("user_id") @db.Uuid
  concertId     String @map("concert_id") @db.Uuid
  reservationId String @unique @map("reservation_id") @db.Uuid

  idempotencyKey String @unique @map("idempotency_key") @db.VarChar(128)

  status OrderStatus @default(PENDING_PAYMENT)

  paymentRetryCount Int       @default(0) @map("payment_retry_count")
  lastRetryAt       DateTime? @map("last_retry_at") @db.Timestamptz(6)

  totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)

  paymentMethod PaymentMethod? @map("payment_method")
  paymentRef    String?        @unique @map("payment_ref") @db.VarChar(100)

  paidAt    DateTime? @map("paid_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User        @relation(fields: [userId], references: [id])
  concert     Concert     @relation(fields: [concertId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id])

  items         OrderItem[]
  paymentEvents PaymentEvent[]
  tickets       Ticket[]

  @@index([userId])
  @@index([status, expiresAt])
  @@map("orders")
}

model OrderItem {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String @map("order_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@unique([orderId, ticketTypeId])
  @@index([ticketTypeId])
  @@map("order_items")
}

model PaymentEvent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  orderId String @map("order_id") @db.Uuid

  gateway              PaymentGateway
  gatewayTransactionId String         @map("gateway_transaction_id") @db.VarChar(100)
  eventType            String         @map("event_type") @db.VarChar(50)

  rawPayload     Json    @map("raw_payload")
  signatureValid Boolean @default(false) @map("signature_valid")

  status      String    @default("PROCESSING") @db.VarChar(20)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id])

  @@unique([gateway, gatewayTransactionId, eventType])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_events")
}

/**
 * =========================
 * TICKETS / QR / CHECK-IN
 * =========================
 */

model Ticket {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  orderId      String @map("order_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid
  ownerUserId  String @map("owner_user_id") @db.Uuid

  ticketCode String @unique @map("ticket_code") @db.VarChar(50)

  /**
   * QR payload là JWT/JWS signed token.
   * Payload gợi ý:
   * {
   * ticket_id,
   * ticket_code,
   * concert_id,
   * ticket_type_id,
   * exp
   * }
   */
  qrPayload String @map("qr_payload")

  seatNumber String? @map("seat_number") @db.VarChar(30)

  status TicketStatus @default(ACTIVE)

  scannedAt     DateTime? @map("scanned_at") @db.Timestamptz(6)
  scannedById   String?   @map("scanned_by") @db.Uuid
  scannedDevice String?   @map("scanned_device") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order      Order      @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  owner      User       @relation("TicketOwner", fields: [ownerUserId], references: [id])
  scannedBy  User?      @relation("TicketScannedBy", fields: [scannedById], references: [id])

  checkinEvents CheckinEvent[]

  @@index([orderId])
  @@index([ownerUserId])
  @@index([status])
  @@index([ticketTypeId])
  @@index([ticketCode, status])
  @@map("tickets")
}

model CheckinDevice {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  deviceCode  String @unique @map("device_code") @db.VarChar(100)
  staffUserId String @map("staff_user_id") @db.Uuid
  concertId   String @map("concert_id") @db.Uuid

  gateName String? @map("gate_name") @db.VarChar(100)

  status CheckinDeviceStatus @default(ACTIVE)

  lastSyncAt DateTime? @map("last_sync_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  staffUser User    @relation(fields: [staffUserId], references: [id])
  concert   Concert @relation(fields: [concertId], references: [id])

  checkinEvents CheckinEvent[]

  @@index([staffUserId])
  @@index([concertId])
  @@map("checkin_devices")
}

model CheckinEvent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  ticketId    String @map("ticket_id") @db.Uuid
  staffUserId String @map("staff_user_id") @db.Uuid
  deviceId    String @map("device_id") @db.Uuid

  clientEventId String @map("client_event_id") @db.VarChar(100)

  scannedAtClient DateTime? @map("scanned_at_client") @db.Timestamptz(6)
  scannedAtServer DateTime  @default(now()) @map("scanned_at_server") @db.Timestamptz(6)

  mode   CheckinMode
  result CheckinResult

  reason String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket    Ticket        @relation(fields: [ticketId], references: [id])
  staffUser User          @relation(fields: [staffUserId], references: [id])
  device    CheckinDevice @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, clientEventId])
  @@index([ticketId])
  @@index([deviceId])
  @@index([result])
  @@index([createdAt])
  @@map("checkin_events")
}

/**
 * =========================
 * GUEST LIST CSV IMPORT
 * =========================
 */

model GuestImportBatch {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  concertId String @map("concert_id") @db.Uuid

  fileUrl  String  @map("file_url") @db.VarChar(500)
  /// Nullable by design: Prisma cannot express a partial unique index.
  /// Enforce uniqueness for non-null hashes with a custom migration:
  /// CREATE UNIQUE INDEX uq_guest_import_batch_hash
  /// ON guest_import_batches(concert_id, file_hash)
  /// WHERE file_hash IS NOT NULL;
  fileHash String? @map("file_hash") @db.VarChar(128)

  status GuestImportStatus @default(PENDING)

  totalRows   Int @default(0) @map("total_rows")
  validRows   Int @default(0) @map("valid_rows")
  invalidRows Int @default(0) @map("invalid_rows")

  errorReportUrl String? @map("error_report_url") @db.VarChar(500)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)

  concert Concert @relation(fields: [concertId], references: [id])

  rows      GuestImportRow[]
  guestList GuestList[]

  @@index([concertId])
  @@index([concertId, fileHash])
  @@index([status])
  @@map("guest_import_batches")
}

model GuestImportRow {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  batchId String @map("batch_id") @db.Uuid

  rowNumber Int @map("row_number")

  fullName  String? @map("full_name") @db.VarChar(100)
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(20)
  guestType String? @map("guest_type") @db.VarChar(50)
  guestCode String? @map("guest_code") @db.VarChar(50)

  validationStatus GuestRowStatus @default(PENDING) @map("validation_status")
  errorMessage     String?        @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  batch GuestImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("guest_import_rows")
}

model GuestList {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  concertId String @map("concert_id") @db.Uuid

  fullName  String  @map("full_name") @db.VarChar(100)
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(20)
  guestType String? @map("guest_type") @db.VarChar(50)
  guestCode String  @map("guest_code") @db.VarChar(50)

  status GuestStatus @default(ACTIVE)

  csvBatchId String? @map("csv_batch_id") @db.Uuid

  scannedAt   DateTime? @map("scanned_at") @db.Timestamptz(6)
  scannedById String?   @map("scanned_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  concert   Concert           @relation(fields: [concertId], references: [id])
  csvBatch  GuestImportBatch? @relation(fields: [csvBatchId], references: [id])
  scannedBy User?             @relation("GuestScannedBy", fields: [scannedById], references: [id])

  @@unique([concertId, guestCode])
  @@index([concertId])
  @@index([guestCode])
  @@map("guest_list")
}

/**
 * =========================
 * AI ARTIST BIO
 * =========================
 */

model ArtistAsset {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  concertId String @map("concert_id") @db.Uuid

  fileUrl          String  @map("file_url") @db.VarChar(500)
  fileType         String? @map("file_type") @db.VarChar(50)
  originalFileName String? @map("original_file_name") @db.VarChar(255)

  status AssetStatus @default(UPLOADED)

  extractedText String? @map("extracted_text")
  generatedBio  String? @map("generated_bio")
  errorMessage  String? @map("error_message")

  uploadedById String? @map("uploaded_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  concert    Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("ArtistAssetUploadedBy", fields: [uploadedById], references: [id])

  @@index([concertId])
  @@map("artist_assets")
}

/**
 * =========================
 * NOTIFICATION / IDEMPOTENCY / WAITING ROOM / AUDIT
 * =========================
 */

model Notification {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String? @map("user_id") @db.Uuid

  channel  NotificationChannel
  template String              @db.VarChar(50)

  payload Json?

  status     NotificationStatus @default(PENDING)
  retryCount Int                @default(0) @map("retry_count")

  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("notifications")
}

model IdempotencyRecord {
  key String @id @db.VarChar(128)

  userId String? @map("user_id") @db.Uuid

  /// Application-level idempotency invariant:
  /// same key + same request body returns the stored response;
  /// same key + different requestHash must return 409 Conflict.
  /// Do not make this globally unique because hash algorithms may change.
  requestHash String @map("request_hash") @db.VarChar(128)

  status IdempotencyStatus @default(PROCESSING)

  responseStatus Int?  @map("response_status")
  responseBody   Json? @map("response_body")

  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([expiresAt])
  @@map("idempotency_records")
}

model WaitingRoomSession {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  concertId String @map("concert_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  token String @unique @db.VarChar(128)

  /// Snapshot position assigned when the user enters the queue.
  /// If the queue becomes dynamic, compute current position from Redis instead of
  /// mutating this value as users leave or are admitted.
  position Int?

  status WaitingRoomStatus @default(WAITING)

  admittedAt DateTime? @map("admitted_at") @db.Timestamptz(6)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  concert Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([concertId, userId])
  @@index([concertId, status])
  @@index([token])
  @@map("waiting_room_sessions")
}

model AuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid

  action       String  @db.VarChar(100)
  resourceType String? @map("resource_type") @db.VarChar(50)
  resourceId   String? @map("resource_id") @db.Uuid

  /// Expected JSONB shape examples:
  /// { "before": {...}, "after": {...}, "diff": {...}, "ip": "...", "userAgent": "..." }
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([resourceType, resourceId])
