    {
      "name": "Auth",
      "description": "AuthModule endpoints from src/routes/auth/auth.controller.ts. Refresh token is stored as an httpOnly cookie named refreshToken on /auth/refresh. Use Seed Admin Login after running npm run db:seed with SEED_ADMIN_* env vars when testing protected Concert routes.",
      "item": [
        {
          "name": "POST /auth/register - Register test account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.collectionVariables.set('testEmail', `ticketbox.user.${timestamp}@example.com`);",
                  "pm.collectionVariables.set('testPhone', `09${String(timestamp).slice(-8)}`);",
                  "pm.collectionVariables.set('testPassword', 'password123');",
                  "pm.collectionVariables.set('testFullName', 'TicketBox Test User');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data;",
                  "",
                  "pm.test('registered user is returned', function () {",
                  "  pm.expect(user).to.have.property('id');",
                  "  pm.expect(user.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "});",
                  "",
                  "pm.test('registered user has customer role without scope fields', function () {",
                  "  pm.expect(user.roles).to.be.an('array');",
                  "  pm.expect(user.roles.map((role) => role.name)).to.include('customer');",
                  "  user.roles.forEach((role) => {",
                  "    pm.expect(role).to.not.have.property('scopeType');",
                  "    pm.expect(role).to.not.have.property('scopeId');",
                  "  });",
                  "});",
                  "",
                  "pm.collectionVariables.set('userId', user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"phone\": \"{{testPhone}}\",\n  \"password\": \"{{testPassword}}\",\n  \"fullName\": \"{{testFullName}}\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a unique test user each time this request runs. The pre-request script updates testEmail/testPhone/testPassword/testFullName collection variables."
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Login and save access token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "const accessToken = data && data.accessToken;",
                  "",
                  "pm.test('login returns user and access token', function () {",
                  "  pm.expect(data).to.have.property('user');",
                  "  pm.expect(data).to.have.property('accessToken');",
                  "  pm.expect(data.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "});",
                  "",
                  "pm.test('login user has customer role and RBAC permissions', function () {",
                  "  const customerRole = data.user.roles.find((role) => role.name === 'customer');",
                  "  pm.expect(data.user.roles).to.be.an('array');",
                  "  pm.expect(customerRole).to.exist;",
                  "  pm.expect(customerRole).to.not.have.property('scopeType');",
                  "  pm.expect(customerRole).to.not.have.property('scopeId');",
                  "  pm.expect(customerRole.permissions).to.include.members(['concert:read', 'order:create', 'order:read_own', 'payment:create', 'ticket:read_own']);",
                  "});",
                  "",
                  "pm.collectionVariables.set('accessToken', accessToken);",
                  "pm.collectionVariables.set('activeLoginEmail', pm.collectionVariables.get('testEmail'));",
                  "pm.collectionVariables.set('activeExpectedRole', 'customer');",
                  "if (pm.environment.name) {",
                  "  pm.environment.set('accessToken', accessToken);",
                  "}",
                  "pm.collectionVariables.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in with the account created by Register. Saves accessToken and userId as collection variables. Postman should also keep the refreshToken cookie returned by the server."
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Seed admin and save access token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "const accessToken = data && data.accessToken;",
                  "",
                  "pm.test('admin login returns user and access token', function () {",
                  "  pm.expect(data).to.have.property('user');",
                  "  pm.expect(data).to.have.property('accessToken');",
                  "  pm.expect(data.user.email).to.eql(pm.collectionVariables.get('seedAdminEmail'));",
                  "});",
                  "",
                  "pm.test('admin user has RBAC admin permissions', function () {",
                  "  const permissions = data.user.roles.flatMap((role) => role.permissions || []);",
                  "  pm.expect(data.user.roles.map((role) => role.name)).to.include('admin');",
                  "  pm.expect(permissions).to.include('concert:read_admin');",
                  "  pm.expect(permissions).to.include('concert:create');",
                  "  pm.expect(permissions).to.include('concert:update');",
                  "  pm.expect(permissions).to.include('concert:cancel');",
                  "  pm.expect(permissions).to.include('ticket_type:manage');",
                  "  pm.expect(permissions).to.include('order:read_admin');",
                  "  pm.expect(permissions).to.include('ticket:read_admin');",
                  "  pm.expect(permissions).to.include('checker:manage');",
                  "  data.user.roles.forEach((role) => {",
                  "    pm.expect(role).to.not.have.property('scopeType');",
                  "    pm.expect(role).to.not.have.property('scopeId');",
                  "  });",
                  "});",
                  "",
                  "pm.collectionVariables.set('accessToken', accessToken);",
                  "pm.collectionVariables.set('activeLoginEmail', pm.collectionVariables.get('seedAdminEmail'));",
                  "pm.collectionVariables.set('activeExpectedRole', 'admin');",
                  "pm.collectionVariables.set('adminUserId', data.user.id);",
                  "pm.collectionVariables.set('userId', data.user.id);",
                  "if (pm.environment.name) {",
                  "  pm.environment.set('accessToken', accessToken);",
                  "}"
                ]
              }
            }
          ],
