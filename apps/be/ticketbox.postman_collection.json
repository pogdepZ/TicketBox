{
  "info": {
    "_postman_id": "75b17bdb-f1c5-4d8c-bc2d-9fbff4d69a01",
    "name": "TicketBox Backend",
    "description": "Postman collection for the current NestJS backend endpoints. Default baseUrl is http://localhost:3001. Run `npm run dev` before testing. Auth handles account registration/login flows; User handles user/profile management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('health status is ok', function () {",
                  "  pm.expect(pm.response.json()).to.eql({ status: 'ok' });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register - Register account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 201 or 409', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const user = pm.response.json();",
                  "  pm.collectionVariables.set('userId', user.id);",
                  "  pm.test('registered user has email', function () {",
                  "    pm.expect(user.email).to.eql('new.user@ticketbox.local');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new.user@ticketbox.local\",\n  \"phone\": \"0900000005\",\n  \"password\": \"password123\",\n  \"fullName\": \"New User\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registers a new account. Client sends `password`; the backend hashes it into `passwordHash`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "GET /user - List users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response is an array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "const users = pm.response.json();",
                  "if (users.length > 0) {",
                  "  const preferred = users.find((user) => user.email === 'customer@ticketbox.local') || users[0];",
                  "  pm.collectionVariables.set('userId', preferred.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user"
              ]
            },
            "description": "Lists users from Prisma. If seeded data exists, this request stores customer@ticketbox.local or the first returned user into the collection variable `userId`."
          },
          "response": []
        },
        {
          "name": "GET /user/:id - Get user by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 200 or 404', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  pm.test('response user id matches variable', function () {",
                  "    pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('userId'));",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}"
              ]
            },
            "description": "Run `GET /user - List users` first so `userId` is set."
          },
          "response": []
        },
        {
          "name": "PATCH /user/:id - Update user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('fullName was updated', function () {",
                  "  pm.expect(pm.response.json().fullName).to.eql('Customer Demo Updated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Customer Demo Updated\",\n  \"phone\": \"0900000999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}"
              ]
            },
            "description": "Updates the user stored in `userId`. Run `GET /user - List users` first."
          },
          "response": []
        },
        {
          "name": "POST /user - Create managed user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"managed.user@ticketbox.local\",\n  \"phone\": \"0900000006\",\n  \"fullName\": \"Managed User\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user"
              ]
            },
            "description": "Creates a user/profile record without account password. Registration belongs to `POST /auth/register`."
          },
          "response": []
        },
        {
          "name": "DELETE /user/:id - Delete user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}"
              ]
            },
            "description": "Deletes the user stored in `userId`. Use carefully because it removes real database data."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
