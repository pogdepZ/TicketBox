    {
      "name": "Concerts",
      "description": "ConcertModule endpoints from src/routes/concert/concert.controller.ts. GET list/detail are public. Protected routes require Authorization: Bearer {{accessToken}} with RBAC permissions only. There is no data scope check in guards.",
      "item": [
        {
          "name": "POST /concerts - Create draft concert",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "const futureDate = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString();",
                  "pm.collectionVariables.set('concertName', `TicketBox Live ${timestamp}`);",
                  "pm.collectionVariables.set('concertEventDate', futureDate);",
                  "",
                  "const accessToken = pm.collectionVariables.get('accessToken') || pm.environment.get('accessToken') || pm.variables.get('accessToken');",
                  "",
                  "if (!accessToken) {",
                  "  throw new Error('Missing accessToken. Login with a user that has concert:create first.');",
                  "}",
                  "",
                  "pm.request.headers.upsert({",
                  "  key: 'Authorization',",
                  "  value: `Bearer ${accessToken}`",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const concert = json.data || json;",
                  "",
                  "pm.test('draft concert is returned', function () {",
                  "  pm.expect(concert).to.have.property('id');",
                  "  pm.expect(concert.name).to.eql(pm.collectionVariables.get('concertName'));",
                  "  pm.expect(concert.status).to.eql('draft');",
                  "});",
                  "",
                  "pm.collectionVariables.set('concertId', concert.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
