              "raw": "{\n  \"name\": \"{{concertName}}\",\n  \"description\": \"A sample concert created from Postman.\",\n  \"artistName\": \"The TicketBox Band\",\n  \"venueName\": \"TicketBox Arena\",\n  \"venueAddress\": \"123 Nguyen Hue, District 1, Ho Chi Minh City\",\n  \"eventDate\": \"{{concertEventDate}}\",\n  \"seatMapSvg\": \"<svg viewBox=\\\"0 0 100 100\\\"><rect width=\\\"100\\\" height=\\\"100\\\" /></svg>\",\n  \"posterUrl\": \"https://example.com/posters/ticketbox-live.png\"\n}"
